1.START

2.DEFINE constant tv_price = 400.00
DEFINE constant monitor_price = 220.00
DEFINE constant flash_price = 35.20
DEFINE constant hd_price = 150.00
DEFINE constant printer_price = 300.00
DEFINE constant tax_rate = 0.0835

3. DECLARE integer variables:
    qtytv, qtymonitor, qtyflash, qtyhdd, qtyprinter

DECLARE float variables:
    totaltv, totalmonitor, totalflash, totalhd, totalprinter
    subtotal, tax, total

4. PROMPT user: "How Many TVs Were Sold?"
READ qtytv
PROMPT user: "How Many Monitors Were Sold?"
READ qtymonitor
PROMPT user: "How Many Flash Drives Were Sold?"
READ qtyflash
PROMPT user: "How Many Hard Drives Were Sold?"
READ qtyhd
PROMPT user: "How Many Deskjet Printers Were Sold?"
READ qtyprinter

5. CALCULATE:
    totalTV = qtytv × tv_price
    totalMonitor = qtymonitor × monitor_price
    totalFlash = qtyflash × flash_price
    totalHDD = qtyhd × hd_price
    totalPrinter = qtyprinter × printer_price

subtotal = totaltv + totalmonitor + totalflash + totalhd + totalprinter

tax = subtotal × tax_rate

total = subtotal + tax

6. DISPLAY formatted bill:
    QTY  DESCRIPTION  UNIT PRICE  TOTAL PRICE
    Print each item line
    Print Subtotal
    Print Tax
    Print Total

END
